{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["api/**", "sql/**"] }
    },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.svg", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "uploads/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.+\\.(html|js|css|svg|json|png|jpg|ico|webmanifest))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
