<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cabinet Dentaire Dr Exemple — Formule Classic</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: system-ui, -apple-system, sans-serif; color: #333; line-height: 1.6; }

    /* Demo banner */
    .demo-banner {
      position: sticky; top: 0; z-index: 1000;
      background: #2D3A8C; color: #fff; text-align: center;
      padding: 10px 16px; font-size: 14px;
    }
    .demo-banner a { color: #ffd966; margin-left: 12px; text-decoration: none; font-weight: 600; }
    .demo-banner a:hover { text-decoration: underline; }

    /* Header */
    header {
      background: #fff; border-bottom: 1px solid #e0e0e0;
      padding: 24px 16px; text-align: center;
    }
    header h1 { font-size: 28px; color: #2D3A8C; }
    header p { color: #666; font-size: 15px; margin-top: 4px; }

    /* Hero */
    .hero {
      background: #f4f6fb; padding: 60px 16px; text-align: center;
    }
    .hero h2 { font-size: 32px; color: #2D3A8C; margin-bottom: 12px; }
    .hero p { max-width: 560px; margin: 0 auto; color: #555; font-size: 17px; }

    /* Sections */
    section { padding: 48px 16px; max-width: 900px; margin: 0 auto; }
    section h3 { font-size: 24px; color: #2D3A8C; margin-bottom: 24px; text-align: center; }

    /* Services */
    .services-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
    }
    .service-card {
      background: #f9f9fb; border: 1px solid #e8e8ee;
      border-radius: 8px; padding: 24px; text-align: center;
    }
    .service-card h4 { color: #2D3A8C; margin-bottom: 8px; }
    .service-card p { font-size: 14px; color: #666; }

    /* Hours */
    .hours-table { width: 100%; max-width: 500px; margin: 0 auto; border-collapse: collapse; }
    .hours-table td { padding: 10px 16px; border-bottom: 1px solid #eee; }
    .hours-table td:first-child { font-weight: 600; color: #2D3A8C; }

    /* Contact */
    .contact-info { text-align: center; }
    .contact-info p { margin-bottom: 8px; }
    .contact-info a { color: #2D3A8C; }

    /* Map placeholder */
    .map-placeholder {
      width: 100%; height: 260px; background: #e0e4ef;
      border-radius: 8px; display: flex; align-items: center;
      justify-content: center; color: #888; font-size: 15px; margin-top: 24px;
    }

    /* Footer */
    footer {
      background: #2D3A8C; color: #fff; text-align: center;
      padding: 24px 16px; font-size: 14px; margin-top: 32px;
    }
    footer a { color: #ffd966; text-decoration: none; }

    @media (max-width: 600px) {
      .hero h2 { font-size: 24px; }
      section { padding: 32px 16px; }
    }
  </style>
</head>
<body>

  <!-- Demo Banner -->
  <div class="demo-banner">
    Site de demonstration JADOMI Studio
    <a href="/studio/onboarding/">Decouvrir la formule &rarr;</a>
  </div>

  <!-- Header -->
  <header>
    <h1>Cabinet Dentaire Dr Exemple</h1>
    <p>Cabinet de demonstration</p>
  </header>

  <!-- Hero -->
  <div class="hero">
    <h2>Votre sourire, notre priorite</h2>
    <p>Le cabinet du Dr Exemple vous accueille dans un cadre moderne et chaleureux pour tous vos soins dentaires.</p>
  </div>

  <!-- Services -->
  <section>
    <h3>Nos services</h3>
    <div class="services-grid">
      <div class="service-card">
        <h4>Soins conservateurs</h4>
        <p>Traitement des caries, detartrage et polissage dentaire.</p>
      </div>
      <div class="service-card">
        <h4>Implantologie</h4>
        <p>Pose d'implants dentaires pour remplacer les dents manquantes.</p>
      </div>
      <div class="service-card">
        <h4>Orthodontie</h4>
        <p>Alignement dentaire pour enfants et adultes, gouttieres transparentes.</p>
      </div>
      <div class="service-card">
        <h4>Esthetique dentaire</h4>
        <p>Blanchiment, facettes et couronnes ceramiques.</p>
      </div>
    </div>
  </section>

  <!-- Horaires -->
  <section>
    <h3>Horaires d'ouverture</h3>
    <table class="hours-table">
      <tr><td>Lundi</td><td>09h00 — 18h00</td></tr>
      <tr><td>Mardi</td><td>09h00 — 18h00</td></tr>
      <tr><td>Mercredi</td><td>09h00 — 13h00</td></tr>
      <tr><td>Jeudi</td><td>09h00 — 18h00</td></tr>
      <tr><td>Vendredi</td><td>09h00 — 17h00</td></tr>
      <tr><td>Samedi</td><td>Sur rendez-vous</td></tr>
      <tr><td>Dimanche</td><td>Ferme</td></tr>
    </table>
  </section>

  <!-- Contact -->
  <section>
    <h3>Contact</h3>
    <div class="contact-info">
      <p><strong>Adresse :</strong> Cabinet de demonstration</p>
      <p><strong>Telephone :</strong> <a href="tel:">XX XX XX XX XX</a></p>
      <p><strong>Email :</strong> <a href="mailto:demo@jadomi.fr">demo@jadomi.fr</a></p>
    </div>
    <div class="map-placeholder">Carte interactive — emplacement reserve</div>
  </section>

  <!-- Footer -->
  <footer>
    <p>&copy; 2026 Cabinet Dentaire Dr Exemple &middot; Propulse par <a href="/">JADOMI IA</a></p>
  </footer>

</body>
</html>
